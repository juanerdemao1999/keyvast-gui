# Rust build output (root and any per-crate target dirs)
/target/
**/target/

# Local IDE and editor state
/.idea/
/.vscode/
*.swp
*.swo

# Local environment files
.env
.env.*

# Keyvast acquisition outputs
/run-*/
*.kvraw
recording.json
events.csv
integrity.json
benchmark.json
log.txt
kvlog.txt
/captures/

